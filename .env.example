# Financial Dashboard - Environment Variables
# Copy this file to .env.local and fill in values as needed.

# ── Required ──────────────────────────────────────────────
# (none — the app works fully without any env vars using mock data)

# ── Optional ──────────────────────────────────────────────

# Finnhub API key for live market data (quotes and news).
# Get a free key at https://finnhub.io/
# When unset, the app uses deterministic mock data — no API calls are made.
FINNHUB_API_KEY=

# Database URL (SQLite). Default is set in prisma/schema.prisma.
# Uncomment to override:
# DATABASE_URL=file:../.data/financial.db
